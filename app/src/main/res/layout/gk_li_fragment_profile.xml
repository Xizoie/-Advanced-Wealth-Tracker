<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/gk_li_tv_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="სახელი: Giorgi"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/gk_li_tv_surname"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="გვარი: Khizanashvili"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/gk_li_tv_name"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/gk_li_tv_birth"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="დაბადების დღე: 28"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/gk_li_tv_surname"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/gk_li_tv_k"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="K კოეფიციენტი: 0.6786"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/gk_li_tv_birth"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>